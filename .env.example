# Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Recommended for new Supabase projects.
# Paste the publishable key from Project Settings > API Keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy compatibility with the initial project specification.
# Use this only if your Supabase project still exposes an anon key instead of a publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
